# Database
# 로컬 개발용 (SQLite)
DATABASE_URL=sqlite:///./ax_oversea.db
# 프로덕션용 (PostgreSQL - Railway 자동 제공)
# DATABASE_URL=postgresql://user:password@host:port/database

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# External APIs
NEWSAPI_KEY=your-newsapi-key-here
CALENDARIFIC_API_KEY=your-calendarific-key-here

# CORS
# 로컬 개발용
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# 프로덕션용 (배포 후 Vercel URL로 변경)
# CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# Admin Account
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=whdbswo12#

# Email Notification Settings (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
ADMIN_EMAILS=admin1@company.com,admin2@company.com

# Claude API Settings (Optional - for AI summarization)
CLAUDE_API_KEY=sk-ant-api...
